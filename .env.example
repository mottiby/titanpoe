# Copy to .env and fill in. Order of priority matches the Phase 0 roadmap.

# ─── Task 3 · Database ── Neon (free Postgres): https://neon.tech
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DB?sslmode=require"

# ─── Task 4 · Auth ── Auth.js + Discord OAuth: https://discord.com/developers/applications
AUTH_SECRET=""                         # generate with: npx auth secret
AUTH_DISCORD_ID=""
AUTH_DISCORD_SECRET=""

# ─── Task 5 · Payments + Escrow + KYC ── Stripe (Test mode + Connect): https://dashboard.stripe.com
STRIPE_SECRET_KEY="sk_test_..."
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."

# ─── Task 6 · Integrations (create when we reach them) ───
SENTRY_DSN=""                          # https://sentry.io
RESEND_API_KEY=""                      # https://resend.com
PUSHER_APP_ID=""                       # https://pusher.com
PUSHER_KEY=""
PUSHER_SECRET=""
NEXT_PUBLIC_PUSHER_KEY=""
