# Normalize line endings: LF in the repo, auto on checkout.
* text=auto eol=lf

# Treat known binary assets as binary (no EOL conversion, no diff noise).
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.webp binary
*.ico binary
*.svg text eol=lf
*.pdf binary
*.woff binary
*.woff2 binary
*.ttf binary
*.otf binary
*.eot binary
*.mp4 binary
*.webm binary
*.zip binary
